# Copy this file to .env and fill in your values.

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model to use for all educational tasks.
# NOTE: gemini-1.5-pro and all Gemini 1.x models have been fully shut down
# by Google. Use a current model such as gemini-2.5-flash (fast/cheap) or
# gemini-2.5-pro (higher quality). Check https://ai.google.dev/gemini-api/docs/models
# for the latest available models if this ever 404s again.
GEMINI_MODEL=gemini-2.5-flash

# If GEMINI_API_KEY is left blank, EduGenie automatically falls back to the
# local LaMini-Flan-T5 model (downloaded on first use via HuggingFace) --
# but only if you've installed requirements-local-fallback.txt locally.
# Set to "false" to disable the fallback entirely and always require Gemini
# (this is the recommended setting for Vercel/serverless deployments --
# see docs/DEPLOY_VERCEL.md).
ENABLE_LOCAL_FALLBACK=true
LOCAL_MODEL_NAME=MBZUAI/LaMini-Flan-T5-783M

# Host/port for local development
HOST=0.0.0.0
PORT=8000

# Database for accounts + saved history.
# Leave unset for local dev -- automatically uses a local SQLite file.
# On Vercel: Storage tab -> Create Database -> Postgres, then copy the
# provided connection string here (or it may be added automatically as
# POSTGRES_URL -- if so, also add DATABASE_URL pointing to the same value).
DATABASE_URL=sqlite:///./edugenie.db

# Used to sign login sessions. Generate a real one for production with:
#   openssl rand -hex 32
SECRET_KEY=dev-secret-change-me-in-production
