# Copy this file to .env and fill in your values.

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# Gemini model to use for all educational tasks.
GEMINI_MODEL=gemini-1.5-pro

# If GEMINI_API_KEY is left blank, EduGenie automatically falls back to the
# local LaMini-Flan-T5 model (downloaded on first use via HuggingFace) --
# but only if you've installed requirements-local-fallback.txt locally.
# Set to "false" to disable the fallback entirely and always require Gemini
# (this is the recommended setting for Vercel/serverless deployments --
# see docs/DEPLOY_VERCEL.md).
ENABLE_LOCAL_FALLBACK=true
LOCAL_MODEL_NAME=MBZUAI/LaMini-Flan-T5-783M

# Host/port for local development
HOST=0.0.0.0
PORT=8000

# Used to sign login session cookies -- set this to a long random string
# in production (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
SECRET_KEY=change-this-to-a-random-secret

# Where the SQLite database (accounts + history) is stored. Defaults to
# ./data/edugenie.db. On serverless platforms this must point to a writable
# path (e.g. /tmp/edugenie.db) and note the data won't persist between
# deployments/cold starts unless you swap in a hosted database.
DB_PATH=
